# ==========================================
# Polla Futbolera — Variables de Entorno
# ==========================================
# Copia este archivo como .env y configura los valores:
#   cp .env.example .env

# Clave secreta para firmar tokens de sesión (OBLIGATORIO en producción)
# Genera una clave con: python -c "import secrets; print(secrets.token_hex(32))"
POLLA_SECRET=

# Orígenes CORS permitidos (separados por coma, opcional)
# CORS_ORIGINS=https://tudominio.com,https://app.tudominio.com

# Puerto del servidor (default: 8000)
# PORT=8000
